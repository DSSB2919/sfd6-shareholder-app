# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# WhatsApp Business API (360dialog)
# Get from https://360dialog.com after registration
WHATSAPP_API_KEY=your-360dialog-api-key

# JWT Secret (generate a random string, min 32 characters)
JWT_SECRET=your-jwt-secret-min-32-characters-long

# QR Code Secret (generate a random string for QR code signature)
QR_SECRET_KEY=your-qr-secret-key-min-32-characters-long

# Environment
NODE_ENV=production
