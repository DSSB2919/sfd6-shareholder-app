# ============================================
# SFD6 Shareholder App - 环境变量模板
# 复制此文件为 .env.local 用于本地开发
# 在 Vercel Dashboard 配置生产环境变量
# ============================================

# --------------------------------------------
# 基础配置
# --------------------------------------------
NODE_ENV=production

# --------------------------------------------
# Supabase 数据库配置
# 从 Supabase Dashboard → Project Settings → API 获取
# --------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# --------------------------------------------
# JWT 密钥 (用于登录 Token 签名)
# 生成命令: openssl rand -base64 32
# --------------------------------------------
JWT_SECRET=your-random-secret-min-32-chars

# --------------------------------------------
# QR Code 密钥 (用于生成/验证二维码)
# 生成命令: openssl rand -base64 32
# --------------------------------------------
QR_SECRET_KEY=your-qr-secret-key

# --------------------------------------------
# WhatsApp Business API (360dialog)
# 注册: https://360dialog.com
# --------------------------------------------
WHATSAPP_API_KEY=your-360dialog-api-key

# --------------------------------------------
# 可选: 管理员默认密码 (首次部署后应立即修改)
# --------------------------------------------
ADMIN_DEFAULT_PASSWORD=admin123
